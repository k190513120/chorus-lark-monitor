<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.feishu-chat.bulk-stats</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/bytedance/chorus-lark-monitor/deployment/run_bulk_stats.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/bytedance/chorus-lark-monitor</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>

  <!-- 每天北京时间 20:00 刷新群发消息已读统计 -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>20</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/bytedance/chorus-lark-monitor/logs/bulk-stats.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/bytedance/chorus-lark-monitor/logs/bulk-stats.err.log</string>
</dict>
</plist>
